license: "LGPL-3.0-or-later"

synopsis: "A Seminar on Rocq"
description: """
Go to the seminar.
"""

build: [make "-j%{jobs}%"]
install: [make "install"]
depends: [
  "coq" {>= "8.20" & < "9.2"}
]

tags: [
  "category:Computer Science"
]
authors: [
  "Quentin Vermande"
]
