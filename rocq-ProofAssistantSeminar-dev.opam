opam-version: "2.0"
maintainer: "Quentin Vermande <quentin.vermande@orange.fr>"
version: "dev"

homepage: "https://github.com/Tragicus/ProofAssistantSeminar"
dev-repo: "git+https://github.com/Tragicus/ProofAssistantSeminar.git"
